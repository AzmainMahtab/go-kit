# Environment
ENVIRONMENT=development
HTTP_PORT=8080
HTTP_HOST=0.0.0.0

# PostgreSQL
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=elite4print
POSTGRES_PASSWORD=elite4print
POSTGRES_DB=elite4print
POSTGRES_SSLMODE=disable

# Full DSN (optional; if set, overrides individual POSTGRES_* vars)
POSTGRES_DSN=postgres://elite4print:elite4print@postgres:5432/elite4print?sslmode=disable

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# NATS
NATS_URL=nats://nats:4222

# Security
JWT_SECRET_KEY=replace-me-in-production-with-at-least-64-characters-long-secret-key
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d

# Sessions
SESSION_MAX_AGE=7d
SESSION_MAX_CONCURRENT=5

# Rate limiting
RATE_LIMIT_RPS=10
RATE_LIMIT_BURST=20
